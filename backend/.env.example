DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.seu-dominio.com

# Frontend origins allowed to call /api/v1/*.
CORS_ALLOWED_ORIGINS=https://app.seu-dominio.com
CORS_ALLOW_CREDENTIALS=false

# Keep aligned with frontend origins if any CSRF-protected endpoint is exposed.
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.seu-dominio.com

# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional worker broker
REDIS_URL=redis://localhost:6379/0
